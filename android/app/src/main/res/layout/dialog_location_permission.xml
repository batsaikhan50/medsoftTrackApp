<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_circle_teal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#FFFFFF" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Байршлын зөвшөөрөл"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center" />

        <!-- Divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="#00CCCC" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Тасралтгүй байршил хянахын тулд тохиргооноос байршлын зөвшөөрлийг &quot;Үргэлж&quot; болгон тохируулна уу."
            android:textSize="13sp"
            android:textColor="#555555"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- Steps: MN + EN side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- MN box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_border_teal"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MN"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#00CCCC"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Тохиргоо нээх"
                    android:textSize="11sp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="2. Байршил → Үргэлж"
                    android:textSize="11sp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="3. Апп руу буцах"
                    android:textSize="11sp"
                    android:textColor="#333333" />
            </LinearLayout>

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <!-- EN box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_border_gray"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Open Settings"
                    android:textSize="11sp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="2. Location → Always"
                    android:textSize="11sp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="3. Return to the app"
                    android:textSize="11sp"
                    android:textColor="#333333" />
            </LinearLayout>

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:text="Тохиргоо нээх"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00CCCC"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:text="Үргэлжлүүлэх"
            android:textSize="13sp"
            android:textColor="#888888"
            android:background="@android:color/transparent"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>
